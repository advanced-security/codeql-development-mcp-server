{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.20.4",
          "rules": [
            {
              "id": "js/sql-injection",
              "name": "js/sql-injection",
              "shortDescription": {
                "text": "Database query built from user-controlled sources"
              },
              "properties": {
                "tags": ["security"],
                "kind": "path-problem",
                "precision": "high",
                "security-severity": "8.8"
              }
            },
            {
              "id": "js/xss",
              "name": "js/xss",
              "shortDescription": {
                "text": "Cross-site scripting"
              },
              "properties": {
                "tags": ["security"],
                "kind": "path-problem",
                "precision": "high",
                "security-severity": "6.1"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "ruleIndex": 0,
          "message": {
            "text": "SQL injection from user input."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/db.js"
                },
                "region": {
                  "startLine": 42,
                  "startColumn": 5,
                  "endColumn": 38
                }
              }
            }
          ]
        },
        {
          "ruleId": "js/sql-injection",
          "ruleIndex": 0,
          "message": {
            "text": "SQL injection from request body."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/api.js"
                },
                "region": {
                  "startLine": 15,
                  "startColumn": 3,
                  "endColumn": 40
                }
              }
            }
          ]
        },
        {
          "ruleId": "js/xss",
          "ruleIndex": 1,
          "message": {
            "text": "XSS vulnerability."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/views.js"
                },
                "region": {
                  "startLine": 30,
                  "startColumn": 10,
                  "endColumn": 50
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
